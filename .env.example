# ──────────────────────────────────────────────────
# PharmAI — Environment Variables Reference
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The backend reads this from the project root.
# ──────────────────────────────────────────────────

# ── Database (Required) ──────────────────────────
# Neon Serverless PostgreSQL with pgvector
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ── NVIDIA NIM (Required) ───────────────────────
# Get your API key from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# ── Azure Blob Storage (Required for production) ─
# Leave empty to use local filesystem (dev only)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=documents

# ── App ──────────────────────────────────────────
APP_NAME=PharmAI Regulatory Assistant
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/api
UPLOAD_DIR=uploads

# ── CORS ─────────────────────────────────────────
# JSON array of allowed origins
# Local dev:
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production:
# ALLOWED_ORIGINS=["https://phramai-frontend.azurewebsites.net"]

# ── Frontend (Next.js) ──────────────────────────
# Build-time (baked into client JS — set as Docker build arg):
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
# Runtime (server-side proxy — set in Azure App Service config):
# FASTAPI_URL=https://phramai-backend.azurewebsites.net
